---
interface Props {
  slug: string;
  size?: number;
}

const { slug, size = 600 } = Astro.props;

function hash(s: string): number {
  let h = 2166136261;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}

const seed = hash(slug);

function rand(i: number): number {
  let x = (seed ^ Math.imul(i, 2654435761)) >>> 0;
  x ^= x << 13; x >>>= 0;
  x ^= x >>> 17;
  x ^= x << 5; x >>>= 0;
  return (x % 10000) / 10000;
}

const blobs = [0, 1, 2].map((i) => ({
  cx: 200 + rand(i * 7 + 1) * 200,
  cy: 180 + rand(i * 7 + 2) * 200,
  rx: 150 + rand(i * 7 + 3) * 90,
  ry: 120 + rand(i * 7 + 4) * 100,
  rot: rand(i * 7 + 5) * 360,
}));

const palette = ['#cf7858', '#e6b89c', '#1f2440'];
const offset = seed % 3;
const fills = [
  palette[offset],
  palette[(offset + 1) % 3],
  palette[(offset + 2) % 3],
];
---

<svg
  viewBox="0 0 600 480"
  width={size}
  role="img"
  aria-label="Decorative composition of overlapping organic shapes"
  class="blob-mark"
>
  <rect width="600" height="480" fill="#f1ebe1" />
  <g class="blob-stack">
    {blobs.map((b, i) => (
      <ellipse
        cx={b.cx}
        cy={b.cy}
        rx={b.rx}
        ry={b.ry}
        transform={`rotate(${b.rot} ${b.cx} ${b.cy})`}
        fill={fills[i]}
      />
    ))}
  </g>
</svg>

<style>
  .blob-mark {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }

  .blob-stack {
    isolation: isolate;
  }

  .blob-stack > * {
    mix-blend-mode: multiply;
  }
</style>
