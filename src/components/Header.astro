---
import Nav from './Nav.astro';
import { loadGlobal } from '../lib/content';

const { name } = loadGlobal();
---

<header class="site-header" role="banner">
  <div class="container site-header-inner">
    <a href="/" class="wordmark" aria-label={`${name} — go to homepage`}>
      <span class="wordmark-glyph" aria-hidden="true">⨵</span>
      <span class="wordmark-name">{name}</span>
    </a>
    <Nav />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    background-color: rgb(216 198 173 / 0.86);
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    z-index: var(--z-header);
  }

  .site-header::after {
    content: '';
    position: absolute;
    inset: auto var(--container-padding) 0;
    border-bottom: 1px solid var(--border);
  }

  .site-header-inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    padding-top: 1.5rem;
    padding-bottom: 0.75rem;
  }

  .wordmark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--ink);
    line-height: 1;
  }

  .wordmark-glyph {
    font-family: 'Apple Symbols', 'Noto Sans Symbols 2', 'Segoe UI Symbol', ui-serif, serif;
    font-size: 1.35rem;
    line-height: 1;
    color: var(--accent);
    transition: color 200ms ease;
  }

  .wordmark-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--ink);
    transition: color 200ms ease;
  }

  .wordmark:hover .wordmark-glyph {
    color: var(--ink);
  }

  .wordmark:hover .wordmark-name {
    color: var(--accent);
  }
</style>
