---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlobMark from '../../components/BlobMark.astro';
import { loadGlobal } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, date, image, image_alt } = post.data;
const global = loadGlobal();

const fmt = new Intl.DateTimeFormat('en-US', { dateStyle: 'long' });
const formattedDate = fmt.format(date);

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: { '@type': 'Organization', name: global.name },
  publisher: { '@type': 'Organization', name: global.name },
};
---

<BaseLayout title={title} description={description} jsonLD={jsonLD}>
  <article class="post">
    <div class="container">
      <div class="post-paper">
        <header class="post-header">
          <time datetime={date.toISOString()} class="post-date">
            {formattedDate}
          </time>
          <h1>{title}</h1>
          <p class="post-description">{description}</p>
        </header>

        <figure class="post-figure">
          {image ? (
            <Image src={image} alt={image_alt ?? title} />
          ) : (
            <BlobMark slug={post.id} />
          )}
        </figure>

        <div class="markdown post-body">
          <Content />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
