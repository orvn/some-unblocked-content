---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadGlobal } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const {
  title,
  description,
  date,
  image,
  image_alt,
  original_url,
  original_author,
} = post.data;

const global = loadGlobal();
const fmt = new Intl.DateTimeFormat('en-US', { dateStyle: 'long', timeZone: 'UTC' });
const formattedDate = fmt.format(date);
const originalHost = new URL(original_url).hostname.replace(/^www\./, '');

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: { '@type': 'Person', name: original_author },
  publisher: { '@type': 'Organization', name: global.name },
  isBasedOn: original_url,
};
---

<BaseLayout title={title} description={description} jsonLD={jsonLD}>
  <article class="post">
    <div class="container">
      <a href="/" class="post-breadcrumb">← Articles</a>

      <header class="post-header">
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        <p class="post-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <span>{original_author}</span>
          <a href={original_url} rel="noopener external" target="_blank">{originalHost}</a>
        </p>
      </header>

      <figure class="post-figure">
        <Image src={image} alt={image_alt ?? title} />
      </figure>

      <div class="markdown post-body">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
