---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { loadGlobal } from '../lib/content';

const global = loadGlobal();

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = new Intl.DateTimeFormat('en-US', { dateStyle: 'long' });

const jsonLD = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: global.name,
  description: global.description,
  url: global.url,
};
---

<BaseLayout description={global.description} jsonLD={jsonLD}>
  <section class="blog-index">
    <div class="container">
      <header class="blog-index-header">
        <h1>{global.name}</h1>
        <p>{global.tagline}.</p>
      </header>

      {posts.length === 0 ? (
        <p class="post-list-empty">No articles yet.</p>
      ) : (
        <ul class="post-list" role="list">
          {posts.map((post) => (
            <li class="post-item">
              <a href={`/b/${post.id}`} class="post-link">
                <time datetime={post.data.date.toISOString()} class="post-date">
                  {fmt.format(post.data.date)}
                </time>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-blurb">{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>
