---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { loadGlobal } from '../lib/content';

const global = loadGlobal();

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = new Intl.DateTimeFormat('en-US', { dateStyle: 'long', timeZone: 'UTC' });
---

<BaseLayout description={global.description}>
  <section class="index-articles">
    <div class="container">
      {posts.length === 0 ? (
        <p class="article-empty">— No articles yet —</p>
      ) : (
        <ul class="article-list">
          {posts.map((post, i) => (
            <li class="article-row">
              <a href={`/b/${post.id}`} class="article-link">
                <span class="article-number">{(i + 1).toString().padStart(3, '0')}</span>
                <div class="article-body">
                  <p class="article-meta">
                    <time datetime={post.data.date.toISOString()}>{fmt.format(post.data.date)}</time>
                    <span>{post.data.original_author}</span>
                  </p>
                  <h2 class="article-title">{post.data.title}</h2>
                  <p class="article-blurb">{post.data.description}</p>
                </div>
                <span class="article-arrow" aria-hidden="true">Read →</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>
